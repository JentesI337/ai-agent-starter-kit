{
  "agent_id": "review-agent",
  "origin": "builtin",
  "enabled": true,
  "display_name": "Review Agent",
  "description": "Read-only reviewer. Analyzes code for quality, security, performance. Never modifies files.",
  "category": "core",
  "role": "reviewer",
  "reasoning_strategy": "verify_first",
  "specialization": "code review & security analysis",
  "capabilities": [
    "review_analysis",
    "security_review",
    "quality_review",
    "read_only",
    "code_reasoning"
  ],
  "constraints": {
    "temperature": 0.2,
    "reflection_passes": 1,
    "reasoning_depth": 2,
    "max_context": null,
    "combine_steps": false
  },
  "tool_policy": {
    "read_only": true,
    "mandatory_deny": [
      "write_file",
      "apply_patch",
      "run_command",
      "code_execute",
      "start_background_command",
      "kill_background_process"
    ],
    "preferred_tools": [
      "read_file",
      "grep_search",
      "file_search",
      "list_code_usages",
      "list_dir"
    ],
    "forbidden_tools": [
      "write_file",
      "apply_patch",
      "run_command",
      "code_execute",
      "start_background_command",
      "spawn_subrun"
    ],
    "additional_deny": [],
    "additional_allow": []
  },
  "prompts": {
    "system": "",
    "plan": "",
    "tool_selector": "",
    "tool_repair": "",
    "final": "",
    "fallback_system_key": "head_agent_system_prompt",
    "fallback_plan_key": "head_agent_plan_prompt",
    "fallback_tool_selector_key": "head_agent_tool_selector_prompt",
    "fallback_tool_repair_key": "head_agent_tool_repair_prompt",
    "fallback_final_key": "head_agent_final_prompt"
  },
  "delegation": {
    "autonomy_level": 5,
    "confidence_threshold": 0.8,
    "delegation_preference": "reluctant",
    "supports_delegation": false,
    "supports_parallel": false,
    "max_concurrent_tasks": 1
  },
  "behavior": {
    "require_review_evidence": true,
    "command_allowlist_regex": null,
    "relaxed_deny": [],
    "custom_deny_override": null
  },
  "custom_workflow": null,
  "cost_tier": "cheap",
  "latency_tier": "standard",
  "quality_tier": "high",
  "version": 1
}