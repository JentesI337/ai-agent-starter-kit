{
  "agent_id": "refactor-agent",
  "origin": "builtin",
  "enabled": true,
  "display_name": "Refactor Agent",
  "description": "Refactoring specialist. Detects code smells, plans safe refactorings, validates with tests.",
  "category": "specialist",
  "role": "specialist",
  "reasoning_strategy": "plan_execute",
  "specialization": "code refactoring & improvement",
  "capabilities": [
    "refactoring",
    "code_smell_detection",
    "pattern_application",
    "safe_transformation",
    "test_validation"
  ],
  "constraints": {
    "temperature": 0.2,
    "reflection_passes": 2,
    "reasoning_depth": 3,
    "max_context": null,
    "combine_steps": false
  },
  "tool_policy": {
    "read_only": false,
    "mandatory_deny": [],
    "preferred_tools": [
      "read_file",
      "grep_search",
      "file_search",
      "write_file",
      "apply_patch",
      "run_command",
      "code_execute",
      "list_code_usages"
    ],
    "forbidden_tools": [],
    "additional_deny": [],
    "additional_allow": []
  },
  "prompts": {
    "system": "",
    "plan": "",
    "tool_selector": "",
    "tool_repair": "",
    "final": "",
    "fallback_system_key": "refactor_agent_system_prompt",
    "fallback_plan_key": "head_agent_plan_prompt",
    "fallback_tool_selector_key": "head_agent_tool_selector_prompt",
    "fallback_tool_repair_key": "head_agent_tool_repair_prompt",
    "fallback_final_key": "refactor_agent_final_prompt"
  },
  "delegation": {
    "autonomy_level": 6,
    "confidence_threshold": 0.8,
    "delegation_preference": "selective",
    "supports_delegation": true,
    "supports_parallel": false,
    "max_concurrent_tasks": 1
  },
  "behavior": {
    "require_review_evidence": false,
    "command_allowlist_regex": null,
    "relaxed_deny": [],
    "custom_deny_override": null
  },
  "custom_workflow": null,
  "cost_tier": "standard",
  "latency_tier": "standard",
  "quality_tier": "high",
  "version": 1
}