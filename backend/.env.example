LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.3:70b-instruct-q4_K_M
LOCAL_MODEL=llama3.3:70b-instruct-q4_K_M
API_MODEL=minimax-m2:cloud
API_SUPPORTED_MODELS=minimax-m2:cloud,gpt-oss:20b-cloud,qwen3-coder:480b-cloud
API_BASE_URL=http://localhost:11434/api
OLLAMA_BIN=
APP_ENV=development
CORS_ALLOW_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=true
COMMAND_ALLOWLIST_ENABLED=true
# SEC (CFG-03): Shells (bash, sh, powershell, cmd, pwsh) removed to prevent
# allowlist-bypass via sub-shell execution.  Add to COMMAND_ALLOWLIST_EXTRA if needed.
# BUG-3: dir, type, echo, findstr are CMD builtins that fail with shell=False on Windows.
COMMAND_ALLOWLIST=python,py,pip,pytest,uvicorn,git,npm,node,npx,yarn,pnpm,make,cmake,docker,docker-compose,java,javac,mvn,gradle,go,rustc,cargo,dotnet,ls,cat,rg,grep,sed,awk,head,tail,wc,sort,uniq,cp,mv,mkdir,touch,chmod,chown,tar,zip,unzip
COMMAND_ALLOWLIST_EXTRA=xdg-open,open,start,explorer
AGENT_NAME=head-agent
CODER_AGENT_NAME=coder-agent
REVIEW_AGENT_NAME=review-agent
HEAD_AGENT_SYSTEM_PROMPT=You are a neutral head agent. Be concise, factual, and adapt naturally to user intent.
HEAD_AGENT_PLAN_PROMPT=You are a neutral head agent. Return a minimal, context-appropriate plan only when needed.
HEAD_AGENT_FINAL_PROMPT=You are a neutral head agent. Return a concise and directly helpful final answer.
CODER_AGENT_SYSTEM_PROMPT=You are a senior coding agent. Think step-by-step, break tasks into actionable implementation steps, and produce precise developer output.
CODER_AGENT_PLAN_PROMPT=You are a senior coding agent. Return a short actionable implementation plan.
CODER_AGENT_FINAL_PROMPT=You are a senior coding agent. Return a concise final answer with practical next steps.
AGENT_SYSTEM_PROMPT=You are a neutral head agent. Be concise, factual, and adapt naturally to user intent.
AGENT_PLAN_PROMPT=You are a neutral head agent. Return a minimal, context-appropriate plan only when needed.
AGENT_TOOL_SELECTOR_PROMPT=You select tools for a coding task. Strictly follow output format requirements.
AGENT_TOOL_REPAIR_PROMPT=You repair malformed tool selection output into strict JSON only.
AGENT_FINAL_PROMPT=You are a neutral head agent. Return a concise and directly helpful final answer.
WORKSPACE_ROOT=.
MEMORY_MAX_ITEMS=30
MEMORY_PERSIST_DIR=./memory_store
MEMORY_RESET_ON_STARTUP=true
ORCHESTRATOR_STATE_DIR=./state_store
ORCHESTRATOR_STATE_RESET_ON_STARTUP=true
CUSTOM_AGENTS_DIR=./custom_agents
COMMAND_TIMEOUT_SECONDS=60
MAX_USER_MESSAGE_LENGTH=8000
RUNTIME_STATE_FILE=./runtime_state.json
SUBRUN_MAX_SPAWN_DEPTH=2
SUBRUN_MAX_CHILDREN_PER_PARENT=5
SUBRUN_ANNOUNCE_RETRY_MAX_ATTEMPTS=5
SUBRUN_ANNOUNCE_RETRY_BASE_DELAY_MS=500
SUBRUN_ANNOUNCE_RETRY_MAX_DELAY_MS=10000
SUBRUN_ANNOUNCE_RETRY_JITTER=true
SESSION_VISIBILITY_DEFAULT=tree
PERSIST_TRANSFORM_MAX_STRING_CHARS=8000
PERSIST_TRANSFORM_REDACT_SECRETS=true

# --- Code Interpreter / Persistent REPL ---
REPL_ENABLED=true
REPL_TIMEOUT_SECONDS=60
REPL_MAX_MEMORY_MB=512
REPL_MAX_SESSIONS=10
REPL_MAX_OUTPUT_CHARS=10000
# REPL_SANDBOX_DIR=          # Leave empty for system temp dir

# --- Browser Control (Playwright) ---
BROWSER_ENABLED=true
BROWSER_MAX_CONTEXTS=5
BROWSER_NAVIGATION_TIMEOUT_MS=30000
BROWSER_CONTEXT_TTL_SECONDS=300
BROWSER_MAX_PAGE_TEXT_CHARS=5000

# --- RAG Engine ---
RAG_ENABLED=false
RAG_EMBEDDING_PROVIDER=ollama          # "ollama" or "openai"
RAG_EMBEDDING_MODEL=nomic-embed-text
RAG_EMBEDDING_BASE_URL=http://localhost:11434
# RAG_EMBEDDING_API_KEY=               # Required for openai provider
RAG_PERSIST_DIR=./chroma_data
RAG_MAX_CHUNKS_PER_COLLECTION=10000
RAG_DEFAULT_TOP_K=5
